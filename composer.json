{
    "name": "apimatic-sdks/m1forgefinanceapis",
    "description": "Stock and Forex Data and Realtime Quotes",
    "type": "library",
    "keywords": [
        "1Forge Finance APIs",
        "API",
        "SDK"
    ],
    "homepage": "http://1forge.com",
    "license": [
        "MIT"
    ],
    "authors": [
        {
            "name": "1Forge",
            "email": "contact@1forge.com",
            "homepage": "http://1forge.com"
        }
    ],
    "prefer-stable": false,
    "require": {
        "php": "^7.2 || ^8.0",
        "ext-json": "*",
        "ext-curl": "*",
        "apimatic/unirest-php": "^4.0.6",
        "apimatic/core-interfaces": "~0.1.5",
        "apimatic/core": "~0.3.17"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.5",
        "phan/phan": "5.4.5"
    },
    "autoload": {
        "psr-4": {
            "M1ForgeFinanceAPIsLib\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "M1ForgeFinanceAPIsLib\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint-src": "phpcs --standard=phpcs-ruleset.xml src/",
        "lint-src-fix": "phpcbf --standard=phpcs-ruleset.xml src/",
        "analyze": "phan --allow-polyfill-parser -p",
        "lint": [
            "@lint-src"
        ]
    }
}